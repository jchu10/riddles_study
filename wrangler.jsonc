{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "riddles",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true
  }},
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
